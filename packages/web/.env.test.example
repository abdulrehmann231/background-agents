# =============================================================================
# E2E test overrides — copy to packages/web/.env.test.
#
# This file only contains values that DIFFER from your dev setup.
# Shared secrets (DAYTONA_API_KEY, NEXTAUTH_SECRET, etc.) come from
# root .env.local via the cascade in playwright.config.ts.
#
# IMPORTANT: Use a SEPARATE test database, NOT your production database.
# Tests run `prisma migrate reset --force` before every run.
# =============================================================================

# Test Database (REQUIRED)
# The URL MUST contain 'test', 'localhost', or '127.0.0.1' as a safety check.
# Set I_KNOW_THIS_IS_THE_TEST_DB=true to bypass.
DATABASE_URL="postgresql://user:password@host/testdb?sslmode=require"
